{
  "id": "be.telenut.elekeeper",
  "version": "1.2.1",
  "brandColor": "#3A3A3A",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "elekeeper"
  },
  "description": {
	"en": "Bring your SAJ eSolar inverter into Homey and automate your home with real-time solar data.",
    "nl": "Koppel je SAJ eSolar omvormer aan Homey en automatiseer je huis met realtime zonne-energie."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "assets/images/small.png",
    "large": "assets/images/large.png"
  },
  "author": {
    "name": "Steven Algoet",
    "email": "telenut@gmail.com"
  },
  "support": "https://community.homey.app/t/app-pro-elekeeper-saj-esolar-inverters/152892",
  "drivers": [
    {
      "id": "inverter",
      "name": {
        "en": "Elekeeper Inverter",
        "nl": "Elekeeper Omvormer"
      },
      "class": "solarpanel",
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "capabilities": [
        "measure_power",
        "meter_power",
        "meter_power.today"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "title": {
            "en": "Total yield",
            "nl": "Totale opbrengst"
          }
        },
        "meter_power.today": {
          "title": {
            "en": "Yield today",
            "nl": "Dagopbrengst"
          }
        }
      },
      "pair": [
        {
          "id": "start"
        }
      ],
      "images": {
        "small": "drivers/inverter/assets/images/small.png",
        "large": "drivers/inverter/assets/images/large.png"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "power_changed",
        "title": {
          "en": "Power changed",
          "nl": "Vermogen is veranderd"
        },
        "tokens": [
          {
            "id": "power",
            "name": "power",
            "type": "number",
            "title": {
              "en": "Current Power",
              "nl": "Actueel vermogen"
            }
          }
        ]
      },
      {
        "id": "today_yield_changed",
        "title": {
          "en": "Today yield changed",
          "nl": "Dagopbrengst is veranderd"
        },
        "tokens": [
          {
            "id": "yield",
            "name": "yield",
            "type": "number",
            "title": {
              "en": "Yield Today",
              "nl": "Dagopbrengst"
            }
          }
        ]
      }
    ]
  }
}